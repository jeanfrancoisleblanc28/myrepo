{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deps.qc.ca/schemas/advisor_score.schema.json",
  "title": "OptiRisque Advisor Score",
  "description": "Score automatique du conseiller selon la grille DÉPS à 12 critères (cible 10/10).",
  "type": "object",
  "required": [
    "run_id",
    "score_total",
    "niveau",
    "qualificatif",
    "decision",
    "details_criteres",
    "points_forts",
    "lacunes",
    "corrections_requises"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4}$"
    },
    "horodatage_utc": { "type": "string", "format": "date-time" },
    "score_total": { "type": "integer", "minimum": 0, "maximum": 100 },
    "niveau": {
      "type": "integer",
      "enum": [3, 5, 7, 10],
      "description": "0–49 → 3, 50–69 → 5, 70–89 → 7, 90–100 → 10"
    },
    "qualificatif": {
      "type": "string",
      "enum": ["insuffisant", "acceptable", "standard CIC", "référence DÉPS"]
    },
    "decision": {
      "type": "string",
      "enum": ["prêt CIC", "retour conseiller"]
    },
    "details_criteres": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "libelle", "obtenu", "max", "verdict"],
        "properties": {
          "id": { "type": "integer", "minimum": 1, "maximum": 12 },
          "libelle": { "type": "string" },
          "obtenu": { "type": "number", "minimum": 0 },
          "max": { "type": "number", "minimum": 0 },
          "verdict": { "type": "string", "enum": ["acquis", "partiel", "manquant"] },
          "preuve": { "type": ["string", "null"] }
        }
      }
    },
    "points_forts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lacunes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "corrections_requises": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["critere_id", "action"],
        "properties": {
          "critere_id": { "type": "integer" },
          "action": { "type": "string" },
          "priorite": { "type": "string", "enum": ["bloquante", "haute", "moyenne", "basse"] }
        }
      }
    }
  }
}
